__pycache__/
*.py[cod]
*.egg-info/
.venv/
dist/
.env

# Database files — never commit these
*.db
*.sqlite

# Raw data pulled from external repos/scrapers — too large and re-pullable
data/raw/
data/interim/
data/feature_matrix.parquet

# Model binaries — too large for git, regenerated by weekly retrain workflow
models/*.pkl
models/oof_predictions.parquet

# Small model config files (feature_cols.json, conformal_quantiles.json,
# cv_metrics.csv, etc.) ARE tracked so the predictor works without retraining.

# site/ is intentionally NOT ignored — committed by GitHub Actions for Pages.

.ruff_cache/
.pytest_cache/
